# ── Server host ──────────────────────────────────────────────────────────────
# Local development — bind to all interfaces so the same machine can reach it.
SERVER_HOST=0.0.0.0

# ── Ports ────────────────────────────────────────────────────────────────────
RTMP_PORT=1935
HTTP_PORT=8001
API_PORT=3001

# ── Timers ───────────────────────────────────────────────────────────────────
DISCONNECT_GRACE_MS=30000
HLS_STALE_MS=90000

# 5centsCDN (leave disabled unless you have an active API key)
FIVECENTS_API_BASE=https://api.5centscdn.com/v2
FIVECENTS_API_KEY=
FIVECENTS_ACCOUNT_ID=10244
FIVECENTS_API_PROFILE_ID=1151
FIVECENTS_STREAM_SERVER=209

# Optional manual push (set only if you are using Railway / a manual push provider
# and the server itself is running there). Leave blank for local development.
MANUAL_PUSH_RTMP_URL=
MANUAL_PUSH_STREAM_KEY=
MANUAL_PUSH_HLS_URL=
STORAGE_ENABLED=false

# Optional API secret for authenticated write endpoints.
API_SECRET=
