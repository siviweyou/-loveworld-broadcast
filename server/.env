# ── Server host ──────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
PUBLIC_HOST=my-stream-media-production.up.railway.app
PUBLIC_SCHEME=https
PUBLIC_RTMP_URL=rtmp://interchange.proxy.rlwy.net:53553/live
PUBLIC_HLS_BASE=https://my-stream-media-production.up.railway.app/live

# ── Ports ─────────────────────────────────────────────────────────────────––
RTMP_PORT=1935
HTTP_PORT=8000
API_PORT=3001

# ── Timers ───────────────────────────────────────────────────────────────────
DISCONNECT_GRACE_MS=30000
HLS_STALE_MS=90000

# 5centsCDN (leave disabled for Railway-only mode)
FIVECENTS_API_BASE=https://api.5centscdn.com/v2
FIVECENTS_API_KEY=
FIVECENTS_ACCOUNT_ID=10244
FIVECENTS_API_PROFILE_ID=1151
FIVECENTS_STREAM_SERVER=209

# Manual push / Railway ingest
MANUAL_PUSH_RTMP_URL=rtmp://interchange.proxy.rlwy.net:53553/live
MANUAL_PUSH_STREAM_KEY=global-main
MANUAL_PUSH_HLS_URL=https://my-stream-media-production.up.railway.app/live
STORAGE_ENABLED=false

# Optional API secret for authenticated write endpoints.
API_SECRET=
